# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Google Gemini API Key
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-gemini-api-key-here

# Cloud Run Scan Gateway (optional)
# If both variables are set, scan extraction routes use Cloud Run instead of direct API calls.
CLOUD_RUN_URL=https://your-cloud-run-service-url
CLOUD_RUN_AUTH_TOKEN=your-cloud-run-shared-token

# Cloud Run fallback controls (configured on Cloud Run service)
# Gemini failures can fallback to OpenAI with breaker/cap controls.
FALLBACK_OPENAI_MODEL=gpt-4o-mini
FALLBACK_CALLS_DAILY_CAP=100
FALLBACK_COST_DAILY_CAP_YEN=300
FALLBACK_ESTIMATED_YEN_PER_CALL=3
FALLBACK_BREAKER_OPEN_MS=300000
GATEWAY_COST_DAILY_CAP_YEN=900
GATEWAY_FIRESTORE_GUARD_ENABLED=true
GATEWAY_FIRESTORE_GUARD_FAIL_CLOSED=true
GATEWAY_GUARD_STATE_DOC=ops/aiGatewayGuard
# Dynamic cost guard (replaces the old fixed GATEWAY_ESTIMATED_YEN_PER_CALL).
# See cloud-run-scan/src/pricing/pricing.ts for the model price table.
GATEWAY_USD_TO_JPY_RATE=155
GATEWAY_FLAT_FALLBACK_USD=0.05
# 0 disables this secondary safety cap on calls priced without real usage data.
GATEWAY_USAGE_MISSING_CALLS_DAILY_CAP=0
# false (default): unpriced models fall back to a conservative flat estimate.
# true: unpriced models are rejected with 429 reason=unpriced_model_blocked.
GATEWAY_BLOCK_UNPRICED_MODELS=false
APP_ENV=prod
# Feedback proxy target for src/app/api/feedback (optional)
FEEDBACK_BACKEND_URL=https://merken-feedback.weallmartians.workers.dev/feedback
# Optional Slack webhook for fallback alerts (Cloud Run only)
FALLBACK_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OAuth buttons are hidden unless the matching Supabase Auth provider is enabled.
# Set after configuring Authentication > Providers and redirect URLs.
NEXT_PUBLIC_AUTH_OAUTH_PROVIDERS=
# Internal worker auth (recommended for Cron/internal async routes)
# Keep this in sync with Supabase Vault secret `internal_worker_token`.
INTERNAL_WORKER_TOKEN=your-internal-worker-token
# Disable only if stats sync migrations have not been applied.
NEXT_PUBLIC_ENABLE_REMOTE_STATS_SYNC=true
ADMIN_SECRET=your-admin-secret

# Stripe
# Get these from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Stripe Price ID for Pro plan (Dashboard > Products > Pricing)
STRIPE_PRICE_ID=price_your-price-id

# Apple IAP (Phase 2/3 preparation)
# Get these from App Store Connect > Users and Access > Integrations > In-App Purchase
APPLE_IAP_ISSUER_ID=99b16628-15e4-4668-972b-eeff55eeff55
APPLE_IAP_KEY_ID=ABCDEFGHIJ
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_IAP_BUNDLE_ID=com.example.app
APPLE_IAP_ENV=production
# Required in production verification flow
APPLE_IAP_APP_APPLE_ID=1234567890
# Server-side allowed App Store product ids (CSV)
IAP_PRO_PRODUCT_IDS=com.example.merken.pro.monthly

# API cost estimation (optional)
# 1 USD = this many JPY for estimated conversion
API_COST_USD_TO_JPY=150

# AI route auth + usage limits
REQUIRE_AUTH_TRANSLATE=true
REQUIRE_AUTH_GENERATE_EXAMPLES=true
REQUIRE_AUTH_DICTATION_GRADE=true
ENABLE_AI_USAGE_LIMITS=true
AI_LIMIT_TRANSLATE_FREE_DAILY=100
AI_LIMIT_TRANSLATE_PRO_DAILY=500
AI_LIMIT_EXAMPLES_FREE_DAILY=15
AI_LIMIT_EXAMPLES_PRO_DAILY=150
AI_LIMIT_DICTATION_FREE_DAILY=10
AI_LIMIT_DICTATION_PRO_DAILY=60

# Dictation model routing
DICTATION_PRIMARY_MODEL=gpt-4o-mini
DICTATION_FALLBACK_MODEL=gpt-4o

# Sentence quiz optimization
SENTENCE_QUIZ_MAX_CONCURRENCY=3
SENTENCE_QUIZ_USE_LEGACY=false

# Resend (Email OTP)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Sentry (Error monitoring)
# Create a project at https://sentry.io and get these values
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.sentry.io/456
SENTRY_DSN=https://your-dsn@o123.ingest.sentry.io/456
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_your-auth-token

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Billing / Pro upgrade funnel. Enabled by default; set to false only as a
# kill switch to hide all upgrade CTAs and the /pricing・/subscription pages.
NEXT_PUBLIC_BILLING_ENABLED=true

# Google ads (optional)
# AdSense client + display slot ids
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=ca-pub-your-client-id
# Gates display ad units only. The review snippet, google-adsense-account meta
# tag, and ads.txt are always emitted (AdSense review requires them on-site).
NEXT_PUBLIC_ENABLE_ADSENSE_DISPLAY_ADS=0
NEXT_PUBLIC_GOOGLE_ADSENSE_DESKTOP_LEFT_SLOT=1234567890
NEXT_PUBLIC_GOOGLE_ADSENSE_DESKTOP_RIGHT_SLOT=1234567890
NEXT_PUBLIC_GOOGLE_ADSENSE_MOBILE_INLINE_SLOT=1234567890
NEXT_PUBLIC_GOOGLE_ADSENSE_FLASHCARD_SLOT=1234567890
# In-feed ad card inserted into the reel feed (non-Pro users only)
NEXT_PUBLIC_GOOGLE_ADSENSE_REELS_INFEED_SLOT=1234567890
NEXT_PUBLIC_GOOGLE_ADSENSE_SHOW_PLACEHOLDERS=0
# Google Ad Manager rewarded ad unit path for shared wordbook downloads
NEXT_PUBLIC_GOOGLE_AD_MANAGER_REWARDED_DOWNLOAD_UNIT_PATH=/1234567/merken/rewarded-download

# Web Push (scan completion background notifications)
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Coin system (scan consumption)
# 'true' でコイン制を有効化。未設定/false は従来のPro無制限スキャン
COIN_SYSTEM_ENABLED=false
# Stripe one-time Prices for coin packs (mode=payment)
STRIPE_COIN_PACK_100_PRICE_ID=price_your-coin-100-price-id
STRIPE_COIN_PACK_300_PRICE_ID=price_your-coin-300-price-id
STRIPE_COIN_PACK_1000_PRICE_ID=price_your-coin-1000-price-id

# ChatGPT Custom GPT (GPT Actions) OAuth連携
# GPTビルダーのActions認証(OAuth)に設定するクライアント情報と同じ値にする。
# セットアップ手順: docs/chatgpt-gpt/setup.md
CHATGPT_OAUTH_CLIENT_ID=merken-chatgpt
CHATGPT_OAUTH_CLIENT_SECRET=your-chatgpt-oauth-client-secret
# GPTのOAuth設定を保存すると表示されるcallback URLをカンマ区切りで登録する。
# モバイルアプリ対策で chat.openai.com / chatgpt.com の両ドメイン分が必要。
CHATGPT_OAUTH_ALLOWED_REDIRECT_URIS=https://chat.openai.com/aip/g-your-gpt-id/oauth/callback,https://chatgpt.com/aip/g-your-gpt-id/oauth/callback
