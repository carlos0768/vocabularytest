# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Google Gemini API Key
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-gemini-api-key-here

# Cloud Run Scan Gateway (optional)
# If both variables are set, scan extraction routes use Cloud Run instead of direct API calls.
CLOUD_RUN_URL=https://your-cloud-run-service-url
CLOUD_RUN_AUTH_TOKEN=your-cloud-run-shared-token

# Cloud Run fallback controls (configured on Cloud Run service)
# Gemini failures can fallback to OpenAI with breaker/cap controls.
FALLBACK_OPENAI_MODEL=gpt-4o-mini
FALLBACK_CALLS_DAILY_CAP=1000
FALLBACK_COST_DAILY_CAP_YEN=3000
FALLBACK_ESTIMATED_YEN_PER_CALL=3
FALLBACK_BREAKER_OPEN_MS=300000
APP_ENV=prod
# Optional Slack webhook for fallback alerts (Cloud Run only)
FALLBACK_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Supabase
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Enable only after applying supabase/migrations/013_stats_sync.sql
NEXT_PUBLIC_ENABLE_REMOTE_STATS_SYNC=false
ADMIN_SECRET=your-admin-secret

# KOMOJU
# Get these from KOMOJU dashboard > Settings > API Keys
KOMOJU_SECRET_KEY=your-komoju-secret-key
KOMOJU_WEBHOOK_SECRET=your-webhook-secret

# API cost estimation (optional)
# 1 USD = this many JPY for estimated conversion
API_COST_USD_TO_JPY=150

# Resend (Email OTP)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (scan completion background notifications)
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
